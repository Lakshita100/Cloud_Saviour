# ─── Autonomous Cloud Incident System — Environment Variables ───
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Railway: Add these in Settings → Variables for your service.

# ── Server ──
PORT=8000

# ── Ollama (Local LLM) ──
# Default: http://localhost:11434
# On Railway: use an external Ollama host or switch to Groq/OpenAI
OLLAMA_HOST=http://localhost:11434

# ── n8n Remediation Webhook (Optional) ──
# Automated remediation workflow trigger
N8N_WEBHOOK_URL=http://localhost:5678/webhook/remediation

# ── Frontend URL (for CORS) ──
# Set this to your Vercel/frontend deployment URL
FRONTEND_URL=http://localhost:8080
